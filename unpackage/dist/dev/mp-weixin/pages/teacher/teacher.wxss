
/* ========== 当前活动栏 ========== */
.session-bar.data-v-c604c94d {
  background: linear-gradient(135deg, #1CB0F6 0%, #4F46E5 100%);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 10rpx 28rpx rgba(28, 176, 246, 0.3);
  position: relative;
  overflow: hidden;
}
.session-bar.data-v-c604c94d::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}
.session-bar-empty.data-v-c604c94d {
  background: #fff;
  border: 2rpx dashed var(--primary-light);
  box-shadow: var(--shadow-sm);
}
.session-info.data-v-c604c94d {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  position: relative;
  z-index: 1;
}
.session-label.data-v-c604c94d {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}
.session-bar-empty .session-label.data-v-c604c94d {
  color: var(--text-secondary);
}
.session-title.data-v-c604c94d {
  font-size: 32rpx;
  color: #fff;
  font-weight: 800;
}
.session-title-empty.data-v-c604c94d {
  font-size: 26rpx;
  color: var(--text-placeholder);
  font-weight: 500;
}
.session-end-btn.data-v-c604c94d {
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  margin-right: 16rpx;
  position: relative;
  z-index: 1;
  transition: all 0.18s ease;
}
.session-end-btn.data-v-c604c94d:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.95);
}
.session-end-text.data-v-c604c94d {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.session-dot.data-v-c604c94d {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
  animation: pulse-c604c94d 1.6s infinite;
  position: relative;
  z-index: 1;
}
@keyframes pulse-c604c94d {
0%   { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7);
}
70%  { box-shadow: 0 0 0 16rpx rgba(255, 255, 255, 0);
}
100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
}
}

/* ========== 活动管理按钮组 ========== */
.action-row.data-v-c604c94d {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.btn-action-primary.data-v-c604c94d,
.btn-action-secondary.data-v-c604c94d {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.2;
  border: none;
  position: relative;
  top: 0;
  transition: all 0.18s ease;
  letter-spacing: 1rpx;
}
.btn-action-primary.data-v-c604c94d {
  background: #fff;
  color: var(--primary-deep);
  border: 2rpx solid var(--primary-light);
  box-shadow: 0 6rpx 16rpx rgba(79, 70, 229, 0.12);
}
.btn-action-primary.data-v-c604c94d:active {
  top: 2rpx;
  background: var(--primary-bg);
}
.btn-action-secondary.data-v-c604c94d {
  background: #fff;
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}
.btn-action-secondary.data-v-c604c94d:active {
  top: 2rpx;
  background: #F8FAFC;
}

/* ========== 统计卡片 ========== */
.stats-row.data-v-c604c94d {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.stat-card.data-v-c604c94d {
  flex: 1;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}
.stat-card.data-v-c604c94d::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  border-radius: 28rpx 28rpx 0 0;
}
.stat-total.data-v-c604c94d::before { background: linear-gradient(90deg, #1CB0F6, #4F46E5);
}
.stat-yes.data-v-c604c94d::before   { background: linear-gradient(90deg, #22C55E, #16A34A);
}
.stat-no.data-v-c604c94d::before    { background: linear-gradient(90deg, #F59E0B, #EF4444);
}
.stat-num.data-v-c604c94d {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  letter-spacing: -1rpx;
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  line-height: 1.1;
}
.stat-total .stat-num.data-v-c604c94d { background-image: linear-gradient(135deg, #1CB0F6, #4F46E5);
}
.stat-yes   .stat-num.data-v-c604c94d { background-image: linear-gradient(135deg, #22C55E, #16A34A);
}
.stat-no    .stat-num.data-v-c604c94d { background-image: linear-gradient(135deg, #F59E0B, #EF4444);
}
.stat-lbl.data-v-c604c94d {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 600;
  margin-top: 10rpx;
  display: block;
  letter-spacing: 1rpx;
}

/* ========== 进度条 ========== */
.progress-wrap.data-v-c604c94d {
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}
.progress-bar.data-v-c604c94d {
  flex: 1;
  height: 16rpx;
  background: #E2E8F0;
  border-radius: 999rpx;
  overflow: hidden;
  position: relative;
}
.progress-fill.data-v-c604c94d {
  height: 100%;
  background: linear-gradient(90deg, #1CB0F6 0%, #4F46E5 100%);
  border-radius: 999rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(28, 176, 246, 0.4);
}
.progress-text.data-v-c604c94d {
  font-size: 26rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #1CB0F6, #4F46E5);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  flex-shrink: 0;
}

/* ========== 扫码按钮 ========== */
.btn-scan.data-v-c604c94d {
  background: linear-gradient(135deg, #1CB0F6 0%, #4F46E5 100%);
  color: #fff;
  border: none;
  border-radius: 28rpx;
  padding: 32rpx 0;
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.2;
  width: 100%;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(28, 176, 246, 0.4),
              0 4rpx 0 #0E8CBF;
  position: relative;
  top: 0;
  letter-spacing: 4rpx;
  transition: all 0.18s ease;
}
.btn-scan.data-v-c604c94d:active {
  top: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(28, 176, 246, 0.3),
              0 2rpx 0 #0E8CBF;
}

/* ========== 管理后台入口按钮 ========== */
.btn-admin-entry.data-v-c604c94d {
  background: #fff;
  color: var(--primary-deep);
  border: 2rpx solid var(--border);
  border-radius: 28rpx;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  line-height: 1.2;
  width: 100%;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-sm);
  position: relative;
  top: 0;
  letter-spacing: 2rpx;
  transition: all 0.18s ease;
}
.btn-admin-entry.data-v-c604c94d:active {
  top: 2rpx;
  background: var(--primary-bg);
  border-color: var(--primary-light);
}

/* ========== 签到结果 ========== */
.result-banner.data-v-c604c94d {
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  animation: banner-in-c604c94d 0.3s ease;
}
@keyframes banner-in-c604c94d {
from { transform: translateY(-10rpx); opacity: 0;
}
to   { transform: translateY(0);      opacity: 1;
}
}
.result-ok.data-v-c604c94d {
  background: linear-gradient(135deg, #DCFCE7 0%, #BBF7D0 100%);
  border: 2rpx solid #22C55E;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.2);
}
.result-err.data-v-c604c94d {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  border: 2rpx solid #EF4444;
  box-shadow: 0 8rpx 20rpx rgba(239, 68, 68, 0.15);
}
.result-emoji.data-v-c604c94d {
  font-size: 48rpx;
  line-height: 1;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.result-info.data-v-c604c94d {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.result-msg-text.data-v-c604c94d {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}
.result-name-text.data-v-c604c94d {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* ========== 筛选 ========== */
.filter-row.data-v-c604c94d {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
  background: #fff;
  padding: 8rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--border);
}
.filter-pill.data-v-c604c94d {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}
.pill-active.data-v-c604c94d {
  background: linear-gradient(135deg, #1CB0F6, #4F46E5);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(28, 176, 246, 0.4);
}

/* ========== 学生列表 ========== */
.stu-list.data-v-c604c94d {
  margin-top: 8rpx;
}
.stu-item.data-v-c604c94d {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid var(--border);
  box-shadow: var(--shadow-sm);
  transition: all 0.18s ease;
}
.stu-item.data-v-c604c94d:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(15, 23, 42, 0.06);
}
.stu-avatar.data-v-c604c94d {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  font-weight: 800;
}
.avatar-ok.data-v-c604c94d {
  background: linear-gradient(135deg, #1CB0F6, #4F46E5);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(28, 176, 246, 0.35);
}
.avatar-wait.data-v-c604c94d {
  background: #F1F5F9;
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}
.stu-avatar-letter.data-v-c604c94d {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}
.stu-info.data-v-c604c94d {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.stu-name.data-v-c604c94d {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.stu-phone.data-v-c604c94d {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}
.stu-status.data-v-c604c94d {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}
.stu-time.data-v-c604c94d {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

/* ========== 空状态 ========== */
.empty-state.data-v-c604c94d {
  text-align: center;
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.empty-emoji.data-v-c604c94d {
  font-size: 96rpx;
  line-height: 1;
  opacity: 0.6;
}
.empty-title.data-v-c604c94d {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-secondary);
}
.empty-sub-text.data-v-c604c94d {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

/* ========== 加载更多 ========== */
.load-more-wrap.data-v-c604c94d {
  text-align: center;
  padding: 32rpx;
}
.load-more-text.data-v-c604c94d {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
}

/* ========== 新一轮签到弹层 ========== */
.ns-mask.data-v-c604c94d {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: ns-fade-c604c94d 0.2s ease;
}
@keyframes ns-fade-c604c94d {
from { opacity: 0;
}
to   { opacity: 1;
}
}
.ns-card.data-v-c604c94d {
  width: 640rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 40rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 40rpx 80rpx rgba(15, 23, 42, 0.3);
  animation: ns-pop-c604c94d 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes ns-pop-c604c94d {
from { transform: scale(0.9); opacity: 0;
}
to   { transform: scale(1);   opacity: 1;
}
}
.ns-title.data-v-c604c94d {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
  margin-bottom: 32rpx;
}
.ns-placeholder.data-v-c604c94d {
  color: var(--text-placeholder);
  font-size: 30rpx;
  font-weight: 400;
  line-height: 96rpx;
  height: 96rpx;
  overflow: visible;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}
.ns-option.data-v-c604c94d {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  background: #F8FAFC;
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}
.ns-checkbox.data-v-c604c94d {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 3rpx solid var(--border-strong);
  background: #fff;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  transition: all 0.15s ease;
}
.ns-checkbox-on.data-v-c604c94d {
  background: linear-gradient(135deg, #EF4444, #F59E0B);
  border-color: #EF4444;
}
.ns-check-mark.data-v-c604c94d {
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}
.ns-option-text.data-v-c604c94d {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.ns-option-title.data-v-c604c94d {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.ns-option-sub.data-v-c604c94d {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}
