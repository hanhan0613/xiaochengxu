<view class="container data-v-dbc77958"><text class="page-title data-v-dbc77958">管理后台</text><text class="page-subtitle data-v-dbc77958">上传名单 / 管理签到数据</text><view class="card data-v-dbc77958"><text class="card-heading data-v-dbc77958">上传学生名单</text><text class="card-desc data-v-dbc77958">支持 .xlsx 格式，表头需包含"姓名"和"手机号"列</text><view class="upload-zone data-v-dbc77958" bindtap="{{a}}" hover-class="upload-zone-active"><text class="upload-big-icon data-v-dbc77958">📁</text><text class="upload-main-text data-v-dbc77958">点击选择 Excel 文件</text><text class="upload-sub-text data-v-dbc77958">支持 .xlsx 格式</text></view><view wx:if="{{b}}" class="file-tag data-v-dbc77958"><text class="file-tag-name data-v-dbc77958">{{c}}</text><text class="file-tag-size data-v-dbc77958">{{d}}</text></view><view wx:if="{{e}}" class="preview-area data-v-dbc77958"><text class="preview-heading data-v-dbc77958">预览（共 {{f}} 条数据）</text><view class="preview-tbl data-v-dbc77958"><view class="preview-tbl-head data-v-dbc77958"><text class="preview-cell cell-idx data-v-dbc77958">#</text><text class="preview-cell cell-name data-v-dbc77958">姓名</text><text class="preview-cell cell-phone data-v-dbc77958">手机号</text></view><view wx:for="{{g}}" wx:for-item="item" wx:key="d" class="preview-tbl-row data-v-dbc77958"><text class="preview-cell cell-idx data-v-dbc77958">{{item.a}}</text><text class="preview-cell cell-name data-v-dbc77958">{{item.b}}</text><text class="preview-cell cell-phone data-v-dbc77958">{{item.c}}</text></view><view wx:if="{{h}}" class="preview-tbl-more data-v-dbc77958"><text class="data-v-dbc77958">... 共 {{i}} 条</text></view></view><button class="btn-primary data-v-dbc77958" bindtap="{{k}}" disabled="{{l}}">{{j}}</button></view></view><view class="card data-v-dbc77958"><text class="card-heading data-v-dbc77958">手动添加学生</text><view class="input-group data-v-dbc77958"><text class="input-label data-v-dbc77958">姓名</text><input class="input-field data-v-dbc77958" placeholder="输入学生姓名" placeholder-class="input-placeholder" adjust-position="{{true}}" value="{{m}}" bindinput="{{n}}"/></view><view class="input-group data-v-dbc77958"><text class="input-label data-v-dbc77958">手机号</text><input class="input-field data-v-dbc77958" type="number" maxlength="11" placeholder="输入11位手机号" placeholder-class="input-placeholder" adjust-position="{{true}}" value="{{o}}" bindinput="{{p}}"/></view><button class="btn-primary data-v-dbc77958" bindtap="{{r}}" disabled="{{s}}">{{q}}</button></view><view class="card data-v-dbc77958"><text class="card-heading data-v-dbc77958">数据管理</text><button class="btn-secondary data-v-dbc77958" bindtap="{{t}}">重置所有签到状态</button><button class="btn-danger data-v-dbc77958" bindtap="{{v}}">清空所有学生数据</button></view></view>